# Supabase ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Multi-tenant ------------------------------------------------------------
# The Postgres schema this deployment serves.
#
#   * LEAVE THESE UNSET to enable the /install web wizard — deploy the folder,
#     open /install in the browser, and the shop's schema + tables are created
#     for you. The wizard writes tenant.config.local.json to pin the schema.
#
#   * OR pin it explicitly here (skips the wizard) for a fixed deployment.
#     Both vars must match; NEXT_PUBLIC_ is read by the browser, the other by
#     the server.
#
# TENANT_SCHEMA=shop_mombasa
# NEXT_PUBLIC_TENANT_SCHEMA=shop_mombasa

# Port for `npm start` (shared-tenancy: run each shop instance on its own port).
# Leave unset for 3000. Run a second shop with PORT=3001, a third with 3002, etc.
# PORT=3000

# Used ONLY by the provisioning/sync scripts (not the app). Postgres connection
# string from Supabase > Settings > Database > Connection string (URI). Lets the
# scripts create schemas, expose them to the API, and run upgrades automatically.
# Keep this out of the deployed app's runtime env.
SUPABASE_DB_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# RECOMMENDED for hosted Supabase: a personal access token
# (https://supabase.com/dashboard/account/tokens). Lets the /install wizard and
# scripts expose each new schema to the API automatically via the Management
# API — the reliable way on hosted Supabase. Without it, you must add each new
# schema under Settings > API > Exposed schemas manually.
SUPABASE_ACCESS_TOKEN=

# Daraja / Safaricom M-Pesa ---------------------------------------------
# Sign up at https://developer.safaricom.co.ke and create an app with the
# "Lipa Na M-Pesa Online" product enabled. Use sandbox values until you go live.
DARAJA_ENV=sandbox                    # sandbox | production
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_SHORTCODE=174379               # Sandbox test PayBill (Safaricom-supplied)
DARAJA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
DARAJA_TRANSACTION_TYPE=CustomerPayBillOnline
# CustomerPayBillOnline for PayBill, CustomerBuyGoodsOnline for Till Number.

# Public URL Daraja calls back when the customer enters their PIN. Must be
# HTTPS and reachable from the public internet. In dev, expose your local
# server with ngrok / cloudflared and paste that URL + /api/mpesa/callback.
DARAJA_CALLBACK_URL=https://YOUR-TUNNEL.ngrok.io/api/mpesa/callback

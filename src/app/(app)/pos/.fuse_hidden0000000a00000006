/* SERIAL UNIT PICKER (for serial_tracked products in POS)                    */
/* -------------------------------------------------------------------------- */
function SerialPickerDialog({
  product, existingIds, sym, onConfirm, onClose,
}: {
  product: Product;
  existingIds: string[];
  sym: string;
  onConfirm: (unitIds: string[]) => void;
  onClose: () => void;
}) {
  const [units, setUnits] = useState<{ id: string; serial_no: string; barcode: string | null; cost: number }[]>([]);
  const [search, setSearch] = useState("");
  const [selected, setSelected] = useState<string[]>(existingIds);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    setLoading(true);
    listAvailableUnits(product.id, search).then((r) => {
      if (r.ok) setUnits(r.units || []);
      setLoading(false);
    });
  }, [product.id, search]);

  // Allow scanning: if the search matches exactly one unit's barcode/serial, auto-toggle on Enter.
  function onKeyDown(e: React.KeyboardEvent<HTMLInputElement>) {
    if (e.key !== "Enter") return;
    const q = search.trim();
    if (!q) return;
    const hit = units.find((u) => u.barcode === q || u.serial_no === q);
    if (hit) {
      toggle(hit.id);
      setSearch("");
    }
  }

  function toggle(id: string) {
    setSelected((prev) => prev.includes(id) ? prev.filter((x) => x !== id) : [...prev, id]);
  }

  return (
    <Dialog open onOpenChange={(o) => !o && onClose()}>
      <DialogContent className="max-w-lg">
        <DialogHeader>
          <DialogTitle>Pick units · {product.name}</DialogTitle>
          <DialogDescription>
            Scan or pick which serial-numbered units are being sold. Selected: {selected.length}
          </DialogDescription>
        </DialogHeader>
        <div className="relative mb-2">
          <Search className="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-slate-400" />
          <Input
            autoFocus
            value={search}
            onChange={(e) => setSearch(e.target.value)}
            onKeyDown={onKeyDown}
            placeholder="Scan barcode or search by serial…"
            className="pl-9 h-10 font-mono"
          />
        </div>
        <div className="max-h-[360px] overflow-y-auto border rounded-md">
          {loading ? (
            <div className="p-6 text-center text-sm text-slate-500">
              <Loader2 className="h-5 w-5 animate-spin mx-auto mb-1" /> Loading units…
            </div>
          ) : units.length === 0 ? (
            <div className="p-6 text-center text-sm text-slate-500">No matching units in stock.</div>
          ) : (
            <ul className="divide-y">
              {units.map((u) => {
                const on = selected.includes(u.id);
                return (
                  <li key={u.id}>
                    <button
                      type="button"
                      onClick={() => toggle(u.id)}
                      className={cn(
                        "w-full flex items-center justify-between p-3 text-left text-sm hover:bg-slate-50",
                        on && "bg-blue-50",
                      )}
                    >
                      <div>
                        <div className="font-mono font-medium text-slate-900">{u.serial_no}</div>
                        {u.barcode && <div className="text-xs text-slate-500 font-mono">{u.barcode}</div>}
                      </div>
                      <div className="flex items-center gap-3">
                        <span className="text-xs text-slate-500">cost {formatMoney(u.cost, sym)}</span>
                        {on
                          ? <CheckCircle2 className="h-5 w-5 text-blue-600" />
                          : <span className="h-5 w-5 rounded-full border border-slate-300" />}
                      </div>
                    </button>
                  </li>
                );
              })}
            </ul>
          )}
        </div>
        <div className="text-xs text-slate-500 mt-1">
          Sells {selected.length} × {product.name} @ {formatMoney(product.selling_price, sym)} each
          = <b>{formatMoney(selected.length * Number(product.selling_price), sym)}</b>
        </div>
        <DialogFooter>
          <Button variant="outline" onClick={onClose}>Cancel</Button>
          <Button onClick={() => { onConfirm(selected); onClose(); }}>
            <CheckCircle2 className="h-4 w-4" /> Confirm
          </Button>
        </DialogFooter>
      </DialogContent>
    </Dialog>
  );
}

# =============================================================================
# Provisioning secrets — used ONLY by the scripts (provision:tenant,
# sync:tenants, expose:tenant) and the /install wizard. NOT needed by the
# running app once a shop is set up.
#
# Setup:
#   1. Copy this file to ".env.provisioning" in the project root (next to
#      package.json) — the same folder where you run `npm run ...`.
#   2. Fill in the values from your Supabase dashboard.
#   3. It is git-ignored, so it never gets committed or copied into shops.
#
# Keep this file in ONE place (your provisioning machine). Do NOT put these
# two values in each shop's .env.local — they are powerful, org-wide secrets.
# =============================================================================

# Postgres connection string — Supabase > Settings > Database > Connection
# string (URI). Use the "Session"/direct connection (port 5432). Lets the
# scripts create schemas, run upgrades, and expose schemas.
SUPABASE_DB_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# Personal access token — https://supabase.com/dashboard/account/tokens
# Lets the scripts/wizard expose each new schema to the API automatically
# (the reliable method on hosted Supabase).
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The project URL + keys (also in .env.local). Handy so the scripts can run
# from this one file without depending on a shop's .env.local.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
